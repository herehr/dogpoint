

# Database
DATABASE_URL=postgresql://dogpoint:dogpoint@localhost:5433/dogpoint

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=changeme
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# URLs
# APP_BASE_URL: canonical public site for e-mail links (password reset). If unset, FRONTEND_BASE_URL / PUBLIC_WEB_BASE_URL are used.
APP_BASE_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:3000
PUBLIC_WEB_BASE_URL=http://localhost:5173

# SMTP (transactional mail: password reset, invites, moderation, etc.)
# Required on every deployed environment (dev + prod). Copy the same keys from production or use a dev sender.
# Aliases supported: SMTP_HOST / MAIL_HOST (same for user/pass). See GET /health/email on the backend.
# SendGrid: EMAIL_HOST=smtp.sendgrid.net EMAIL_PORT=587 EMAIL_USER=apikey EMAIL_PASS=<API_KEY>
EMAIL_ENABLED=1
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
# SMTP_HOST=  SMTP_USER=  SMTP_PASS=  (optional aliases)

